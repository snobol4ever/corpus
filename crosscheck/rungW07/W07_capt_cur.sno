* W07_capt_cur — @var captures cursor position as integer string
        subject = 'ABCDE'
        subject ('ABC' @ pos1)  :f(e001)
        OUTPUT = 'PASS W07/001: cursor pos=' pos1   :(t002)
e001    OUTPUT = 'FAIL W07/001: cursor capture should match'
t002    subject = 'ABCDE'
        subject (@ pos2 'ABCDE')  :f(e002)
        OUTPUT = 'PASS W07/002: cursor at start=' pos2   :(END)
e002    OUTPUT = 'FAIL W07/002: cursor at start should match'
END
